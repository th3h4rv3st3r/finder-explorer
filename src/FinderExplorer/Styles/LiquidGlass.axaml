<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!--  Finder Explorer Theme — Mica Alt Dark       -->
    <!--  Inspired by Files Community app             -->
    <!-- ============================================ -->

    <!-- Global font (Files-like) -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#E7EAF0" />
    </Style>

    <!-- ═══════════════ SIDEBAR ═══════════════ -->

    <!-- Section Header (Pinned, Drives, Network...) -->
    <Style Selector="ToggleButton.sidebar-section">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#9DA6B8" />
        <Setter Property="Padding" Value="8,12,12,4" />
        <Setter Property="Margin" Value="4,4,4,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinHeight" Value="24" />
    </Style>

    <Style Selector="ToggleButton.sidebar-section:pointerover">
        <Setter Property="Background" Value="#08FFFFFF" />
    </Style>

    <Style Selector="TextBlock.section-header-label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#9DA6B8" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.section-chevron">
        <Setter Property="Text" Value="▸" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#8993A6" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Width" Value="9" />
    </Style>

    <Style Selector="ToggleButton.sidebar-section:checked TextBlock.section-chevron">
        <Setter Property="Text" Value="▾" />
    </Style>

    <!-- Sidebar Item (button) -->
    <Style Selector="Button.sidebar-item">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#E5EAF2" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="4,0,4,0" />
        <Setter Property="Height" Value="32" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="Button.sidebar-item:pointerover">
        <Setter Property="Background" Value="#14FFFFFF" />
        <Setter Property="BorderBrush" Value="#14FFFFFF" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item:pressed">
        <Setter Property="Background" Value="#1DFFFFFF" />
        <Setter Property="BorderBrush" Value="#1DFFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item.selected">
        <Setter Property="Background" Value="#22FFFFFF" />
        <Setter Property="BorderBrush" Value="#2FFFFFFF" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item.selected:pointerover">
        <Setter Property="Background" Value="#2AFFFFFF" />
        <Setter Property="BorderBrush" Value="#34FFFFFF" />
    </Style>

    <Style Selector="PathIcon.sidebar-pin">
        <Setter Property="Foreground" Value="#7F8AA0" />
    </Style>

    <Style Selector="Button.sidebar-item:pointerover PathIcon.sidebar-pin">
        <Setter Property="Foreground" Value="#A6B0C2" />
    </Style>

    <Style Selector="Button.sidebar-item.selected PathIcon.sidebar-pin">
        <Setter Property="Foreground" Value="#C4CCDA" />
    </Style>

    <!-- ═══════════════ TOOLBAR ═══════════════ -->

    <Style Selector="Button.toolbar-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#AAFFFFFF" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="Button.toolbar-btn:pointerover">
        <Setter Property="Background" Value="#12FFFFFF" />
    </Style>

    <Style Selector="Button.toolbar-btn:pressed">
        <Setter Property="Background" Value="#18FFFFFF" />
    </Style>

    <Style Selector="Button.toolbar-btn:disabled">
        <Setter Property="Foreground" Value="#33FFFFFF" />
    </Style>

    <!-- ═══════════════ BREADCRUMB ═══════════════ -->

    <Style Selector="Button.breadcrumb-segment">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#99FFFFFF" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.breadcrumb-segment:pointerover">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Background" Value="#10FFFFFF" />
    </Style>

    <!-- ═══════════════ FILE LIST ═══════════════ -->

    <Style Selector="Border.file-item">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Margin" Value="0,1" />
    </Style>

    <Style Selector="Border.file-item:pointerover">
        <Setter Property="Background" Value="#0CFFFFFF" />
    </Style>

    <!-- ═══════════════ SCROLLBARS ═══════════════ -->

    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="True" />
    </Style>

</Styles>
