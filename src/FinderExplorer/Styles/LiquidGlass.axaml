<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════════
         Finder Explorer — Complete Theme
         Base: SimpleTheme (não FluentTheme — evita MinHeight/Padding dinâmico)
         Tokens: WinUIColors.axaml (WinUI 3 dark theme equivalents)
         Todos os controles interativos têm templates 100% customizados.
    ══════════════════════════════════════════════════════════════════ -->

    <!-- Fonte global (Segoe UI Variable = WinUI default) -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, sans-serif" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, sans-serif" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         SIDEBAR SECTION HEADER  ToggleButton.sidebar-section
         Matches Files SidebarStyles.xaml "NoChildren" / "Collapsed" / "Expanded" states:
         FontSize=12, FontWeight=SemiBold, Foreground=TextFillColorTertiary
         No icon shown, text margin 8,0,12,0
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="ToggleButton.sidebar-section">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="4,0,4,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Margin="0,2,0,2">
                    <!-- Hover overlay with smooth opacity transition -->
                    <Border x:Name="HoverBd"
                            Background="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}"
                            CornerRadius="{DynamicResource ControlCornerRadius}"
                            Opacity="0">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                            </Transitions>
                        </Border.Transitions>
                    </Border>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.sidebar-section:pointerover /template/ Border#HoverBd">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleButton.sidebar-section:pressed /template/ Border#HoverBd">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>

    <!-- Section label text (matches Files SidebarItem NoChildren/Expanded/Collapsed states) -->
    <Style Selector="TextBlock.section-label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="525" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, sans-serif" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="8,0,12,0" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <!-- Chevron for sidebar sections — no rotation/scale (path not centered, causes wobble).
         Instead, MainWindow uses different icon keys (ChevronDown / ChevronUp) per state. -->
    <Style Selector="PathIcon.section-chevron">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Expanded section adds 12px bottom margin (matches Files "Expanded" state RootPanel Margin=0,0,0,12) -->
    <Style Selector="StackPanel.sidebar-section-children">
        <Setter Property="Margin" Value="0,0,0,0" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         SIDEBAR NAV ITEM  Button.sidebar-item
         Matches Files SidebarStyles.xaml:
         - ElementBorder: Height=32
         - ElementGrid: Margin=0,2,0,2, CornerRadius=ControlCornerRadius, BorderThickness=1
         - Columns: 3(pill) | Auto(icon 16px, margin 8,0,0,0) | *(text, margin 12,0,12,2) | Auto(decorator 28px)
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.sidebar-item">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="4,0,4,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, sans-serif" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Margin="0,2,0,2">
                    <!-- Hover overlay with smooth opacity transition -->
                    <Border x:Name="HoverBd"
                            Background="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}"
                            CornerRadius="{DynamicResource ControlCornerRadius}"
                            Opacity="0">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                            </Transitions>
                        </Border.Transitions>
                    </Border>
                    <!-- Selected state border — 1px inset from hover for separation -->
                    <Border x:Name="SelBd"
                            Background="Transparent"
                            BorderBrush="Transparent" BorderThickness="1"
                            CornerRadius="{DynamicResource ControlCornerRadius}"
                            Margin="1" />
                    <ContentPresenter x:Name="CP"
                                      Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Foreground="{TemplateBinding Foreground}" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Smooth hover/press/selection transitions -->
    <Style Selector="Button.sidebar-item:pointerover /template/ Border#HoverBd">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.sidebar-item:pressed /template/ Border#HoverBd">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>

    <!-- Selected → ControlFillColorDefault + ButtonBorderBrush (matches Files "Selected" / "NormalSelected") -->
    <Style Selector="Button.sidebar-item.selected /template/ Border#SelBd">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
    </Style>

    <!-- Selected + PointerOver → ControlFillColorSecondary -->
    <Style Selector="Button.sidebar-item.selected:pointerover /template/ Border#SelBd">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
    </Style>

    <!-- Selected + Pressed → ControlFillColorTertiary -->
    <Style Selector="Button.sidebar-item.selected:pressed /template/ Border#SelBd">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
    </Style>

    <!-- Selection Indicator Pill (matches Files SelectionIndicator: 3×16, RadiusX=2, AccentFill) -->
    <Style Selector="Border.sel-pill">
        <Setter Property="Width" Value="3" />
        <Setter Property="Height" Value="16" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="2,0,0,0" />
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.sel-pill.on">
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Pin icon in Pinned items (matches Files SidebarFavouritesPinnedIcon: 12×12) -->
    <Style Selector="PathIcon.pin-icon">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.sidebar-item:pointerover PathIcon.pin-icon">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style Selector="Button.sidebar-item.selected PathIcon.pin-icon">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         TOOLBAR  Button.toolbar-btn
         Matches Files ToolbarButtonStyle — subtle fill hover
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.toolbar-btn">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="NaN" />
        <Setter Property="Height" Value="NaN" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="Bd" Background="Transparent"
                        BorderBrush="Transparent" BorderThickness="1"
                        CornerRadius="{DynamicResource ControlCornerRadius}">
                    <ContentPresenter x:Name="CP" Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.toolbar-btn /template/ Border#Bd">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.toolbar-btn:pointerover /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
    </Style>
    <Style Selector="Button.toolbar-btn:pressed /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>
    <Style Selector="Button.media-control-btn">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style Selector="Button.media-control-btn PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style Selector="Button.media-control-btn.alert">
        <Setter Property="Foreground" Value="#FF4D4F" />
    </Style>
    <Style Selector="Button.media-control-btn.alert PathIcon">
        <Setter Property="Foreground" Value="#FF4D4F" />
    </Style>
    <Style Selector="Button.media-control-btn.alert /template/ Border#Bd">
        <Setter Property="BorderBrush" Value="#44FF4D4F" />
    </Style>
    <Style Selector="Slider.media-slider">
        <Setter Property="Foreground" Value="{DynamicResource MediaControlAccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
    </Style>
    <Style Selector="Slider.media-slider Thumb">
        <Setter Property="Background" Value="{DynamicResource MediaControlAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MediaControlAccentBrush}" />
    </Style>
    <Style Selector="Slider.media-slider Thumb /template/ Border">
        <Setter Property="Background" Value="{DynamicResource MediaControlAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MediaControlAccentBrush}" />
    </Style>
    
    <!-- Navigation Button Style (Back, Forward, Up, Refresh)
         Matches Files AddressToolbarButtonStyle 36x32, borderless, precise hover -->
    <Style Selector="Button.nav-btn">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="Bd" Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="{DynamicResource ControlCornerRadius}">
                    <ContentPresenter x:Name="CP" Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.nav-btn /template/ Border#Bd">
        <Setter Property="Transitions"><Transitions><BrushTransition Property="Background" Duration="0:0:0.1" /></Transitions></Setter>
    </Style>
    <Style Selector="Button.nav-btn:pointerover /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
    </Style>
    <Style Selector="Button.nav-btn:pressed /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>
    <Style Selector="Button.nav-btn:disabled /template/ ContentPresenter#CP">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
    </Style>

    <!-- TAB BAR -->
    <Style Selector="Border.tab-header">
        <Setter Property="Height" Value="38" />
        <Setter Property="Width" Value="260" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1,1,1,0" />
        <Setter Property="CornerRadius" Value="8,8,0,0" />
    </Style>
    <Style Selector="Border.tab-header:pointerover">
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Border.tab-header.selected">
        <Setter Property="Background" Value="{DynamicResource App.Theme.BaseLayer.BackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Border.tab-header.selected:pointerover">
        <Setter Property="Background" Value="{DynamicResource App.Theme.BaseLayer.BackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.tab-title-btn">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="MinWidth" Value="176" />
        <Setter Property="MaxWidth" Value="176" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Margin" Value="-2,0,0,0" />
        <Setter Property="Padding" Value="0,0,6,0" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                    <ContentPresenter x:Name="CP"
                                      Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}"
                                      VerticalAlignment="Center"
                                      TextBlock.TextTrimming="CharacterEllipsis" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Border.tab-header.selected Button.tab-title-btn">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style Selector="Button.tab-close-btn">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Border.tab-header.selected Button.tab-close-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="Border.tab-header:pointerover Button.tab-close-btn">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="Button.tab-close-btn:pointerover /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
    </Style>
    <Style Selector="Button.tab-close-btn:pressed /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>
    <Style Selector="PathIcon.tab-close-icon">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="Border.tab-header.selected PathIcon.tab-close-icon">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style Selector="Button.tab-close-btn:pointerover PathIcon.tab-close-icon">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         BREADCRUMB  Button.breadcrumb-btn
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.breadcrumb-btn">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="5,0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="Bd" Background="Transparent"
                        CornerRadius="{DynamicResource ControlCornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter x:Name="CP" Content="{TemplateBinding Content}"
                                      VerticalAlignment="Center" FontSize="14"
                                      Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <!-- Smooth hover transitions -->
    <Style Selector="Button.breadcrumb-btn /template/ Border#Bd">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.breadcrumb-btn:pointerover /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
    </Style>
    <Style Selector="Button.breadcrumb-btn:pointerover /template/ ContentPresenter#CP">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style Selector="Button.breadcrumb-btn:pressed /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>

    <Style Selector="TextBox.search-box">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBox.search-box:focus">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         LISTBOX / LISTBOXITEM — zero overhead
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <ControlTemplate>
                <ScrollViewer AllowAutoHide="True"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsPresenter HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />
                </ScrollViewer>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  HorizontalAlignment="Stretch" />
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         FILE ROW
         Padding=0 — o alinhamento com o header é garantido pelo Margin
         idêntico no Grid pai. MinHeight=30 garante altura de toque ok.
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="Border.file-row">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.file-row:pointerover">
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected Border.file-row">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected Border.file-row:pointerover">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         DETAILS PANE
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.segmented-control">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="MinWidth" Value="84" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <Border x:Name="Bd"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <Border x:Name="SelectionPill"
                            Width="16"
                            Height="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            CornerRadius="1"
                            Background="Transparent" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.segmented-control:pointerover /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
    </Style>
    <Style Selector="Button.segmented-control.active">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style Selector="Button.segmented-control.active /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
    </Style>
    <Style Selector="Button.segmented-control.active /template/ Border#SelectionPill">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>

    <Style Selector="TextBlock.details-header">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style Selector="TextBlock.details-value">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style Selector="Button.details-link">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    </Style>
    <Style Selector="Button.details-link:pointerover">
        <Setter Property="Background" Value="{DynamicResource App.Theme.SurfaceLayer.BackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
    </Style>
    <Style Selector="Button.details-link:pressed">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
    </Style>

    <Style Selector="Button.details-props-btn">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    </Style>
    <Style Selector="Button.details-props-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="Button.details-props-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         SETTINGS DIALOG
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="Border.settings-modal-overlay">
        <Setter Property="Background" Value="#B0000000" />
    </Style>

    <Style Selector="Border.settings-modal-shell">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.settings-nav-pane">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
    </Style>

    <Style Selector="TextBlock.settings-page-title">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.settings-group-title">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.settings-section-title">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.settings-subsection-title">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style Selector="Border.settings-section-card">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Border.settings-option-card">
        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style Selector="Border.settings-option-card:pointerover">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
    </Style>

    <Style Selector="TextBlock.settings-option-caption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="PathIcon.settings-option-icon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.settings-option-card ToggleSwitch">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style Selector="Border.settings-option-card ToggleSwitch /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.settings-option-card ToggleSwitch:checked /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>

    <Style Selector="Border.settings-option-card ToggleSwitch:pointerover /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
    </Style>

    <Style Selector="Border.settings-option-card ToggleSwitch:checked:pointerover /template/ Border#OuterBorder">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>

    <Style Selector="Border.settings-option-card ToggleSwitch /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>

    <Style Selector="Border.settings-option-card ToggleSwitch TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style Selector="TextBox.settings-action-search">
        <Setter Property="MinWidth" Value="220" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style Selector="Button.settings-action-btn">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
    </Style>
    <Style Selector="Button.settings-action-btn:pointerover">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="Button.settings-action-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
    </Style>

    <Style Selector="Border.settings-shortcut-chip">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinWidth" Value="26" />
    </Style>

    <Style Selector="TextBlock.settings-shortcut-chip-text">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.settings-section-card ComboBox">
        <Setter Property="MinHeight" Value="32" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         CAPTION BUTTONS  Button.caption-btn
         Mesmos tokens do sidebar selected: ControlFillColorDefault + ButtonBorderBrush
         Tamanho: 46×32 (igual ao título bar height), ícone 10px
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="Button.caption-btn">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="Bd"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="1"
                        CornerRadius="0">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.15" />
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                        </Transitions>
                    </Border.Transitions>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.caption-btn:pointerover /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
    </Style>
    <Style Selector="Button.caption-btn:pressed /template/ Border#Bd">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
    </Style>
    <!-- Close button: hover vermelho WinUI -->
    <Style Selector="Button.caption-btn-close:pointerover /template/ Border#Bd">
        <Setter Property="Background" Value="#C42B1C" />
        <Setter Property="BorderBrush" Value="#C42B1C" />
    </Style>
    <Style Selector="Button.caption-btn-close:pressed /template/ Border#Bd">
        <Setter Property="Background" Value="#A12018" />
        <Setter Property="BorderBrush" Value="#A12018" />
    </Style>
    <!-- Ícone do close fica branco no hover -->
    <Style Selector="Button.caption-btn-close:pointerover Path">
        <Setter Property="Stroke" Value="#FFFFFF" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         FILE SELECT CHECKBOX — accent color, sem label
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="CheckBox.file-select-checkbox">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Background="{TemplateBinding Background}">
                    <Border x:Name="CheckboxBorder"
                            Background="Transparent"
                            BorderBrush="{DynamicResource TextFillColorTertiaryBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Width="18"
                            Height="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <!-- Bulletproof Segoe Fluent Icon Checkmark -->
                        <TextBlock x:Name="CheckGlyph"
                                   Text="&#xE73E;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Symbols"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="Black"
                                   Opacity="0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Hide completely until Hovered or Selected (handled by ContentArea.axaml Opacity) -->

    <Style Selector="CheckBox.file-select-checkbox:pointerover /template/ Border#CheckboxBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style Selector="CheckBox.file-select-checkbox:checked /template/ Border#CheckboxBorder">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>
    <Style Selector="CheckBox.file-select-checkbox:checked /template/ TextBlock#CheckGlyph">
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         MISC
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="TextBlock.col-header">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="True" />
    </Style>

    <!-- ══════════════════════════════════════════════════════════════════
         SCROLLBAR — thin, subtle, WinUI-style
         Track transparente, thumb 3px (expande para 6px no hover),
         sem botões de seta, fade-in/out suave.
    ══════════════════════════════════════════════════════════════════ -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="12" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid x:Name="Root" Background="Transparent">
                    <Border x:Name="TrackBd"
                            Background="Transparent"
                            CornerRadius="6"
                            Margin="0,2"
                            HorizontalAlignment="Center"
                            Width="6" />
                    <Track x:Name="PART_Track"
                           IsDirectionReversed="True"
                           Minimum="{TemplateBinding Minimum}"
                           Maximum="{TemplateBinding Maximum}"
                           Value="{TemplateBinding Value}"
                           ViewportSize="{TemplateBinding ViewportSize}"
                           Orientation="{TemplateBinding Orientation}">
                        <Track.DecreaseButton>
                            <RepeatButton Classes="scrollbar-line-btn" />
                        </Track.DecreaseButton>
                        <Track.IncreaseButton>
                            <RepeatButton Classes="scrollbar-line-btn" />
                        </Track.IncreaseButton>
                        <Thumb x:Name="thumb"
                               Classes="scrollbar-thumb" />
                    </Track>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Thumb: pílula fina com accent dinâmico do sistema -->
    <Style Selector="Thumb.scrollbar-thumb">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Width" Value="4" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="Opacity" Value="0.82" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="ThumbBd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="3"
                        Margin="{TemplateBinding Margin}">
                    <Border.Transitions>
                        <Transitions>
                            <ThicknessTransition Property="Margin" Duration="0:0:0.15" />
                        </Transitions>
                    </Border.Transitions>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Thumb.scrollbar-thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0.95" />
        <Setter Property="Margin" Value="2,0" />
    </Style>
    <Style Selector="Thumb.scrollbar-thumb:pressed">
        <Setter Property="Opacity" Value="0.98" />
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>

    <!-- Fallback para templates de ScrollBar que não usem classe "scrollbar-thumb" -->
    <Style Selector="ScrollBar Thumb">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0.82" />
    </Style>
    <Style Selector="ScrollBar Thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0.95" />
    </Style>
    <Style Selector="ScrollBar Thumb:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Opacity" Value="0.98" />
    </Style>

    <!-- Garante thumb arredondado também no template padrão do SimpleTheme -->
    <Style Selector="ScrollBar Thumb /template/ Border">
        <Setter Property="CornerRadius" Value="999" />
    </Style>

    <!-- Setas do template padrão: accent dinâmica + cantos arredondados -->
    <Style Selector="ScrollBar RepeatButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ScrollBar RepeatButton:pointerover">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>
    <Style Selector="ScrollBar RepeatButton:pressed">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>
    <Style Selector="ScrollBar:vertical RepeatButton">
        <Setter Property="Width" Value="9" />
        <Setter Property="MinWidth" Value="9" />
        <Setter Property="Height" Value="9" />
        <Setter Property="MinHeight" Value="9" />
    </Style>
    <Style Selector="ScrollBar:horizontal RepeatButton">
        <Setter Property="Width" Value="9" />
        <Setter Property="MinWidth" Value="9" />
        <Setter Property="Height" Value="9" />
        <Setter Property="MinHeight" Value="9" />
    </Style>
    <Style Selector="ScrollBar RepeatButton /template/ Border">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Width" Value="9" />
        <Setter Property="Height" Value="9" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ScrollBar RepeatButton /template/ PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ScrollBar RepeatButton /template/ Path">
        <Setter Property="Fill" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Stroke" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>
    <Style Selector="ScrollBar RepeatButton:pointerover /template/ PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>
    <Style Selector="ScrollBar RepeatButton:pressed /template/ PathIcon">
        <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>
    <Style Selector="ScrollBar RepeatButton:pointerover /template/ Path">
        <Setter Property="Fill" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Stroke" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>
    <Style Selector="ScrollBar RepeatButton:pressed /template/ Path">
        <Setter Property="Fill" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Stroke" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>

    <!-- Sidebar vertical scrollbar: custom template -->
    <Style Selector="ScrollViewer.sidebar-scroll ScrollBar:vertical">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="12" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid RowDefinitions="12,*,12"
                      Background="Transparent">
                    <RepeatButton x:Name="PART_LineUpButton"
                                  Grid.Row="0"
                                  Width="10"
                                  Height="10"
                                  Padding="0"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center">
                        <Path Width="6"
                              Height="4"
                              Data="M 0,4 L 3,0 L 6,4 Z"
                              Fill="{DynamicResource AccentFillColorDefaultBrush}"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </RepeatButton>

                    <Track x:Name="PART_Track"
                           Grid.Row="1"
                           Width="8"
                           Margin="0,2"
                           IsDirectionReversed="True"
                           Minimum="{TemplateBinding Minimum}"
                           Maximum="{TemplateBinding Maximum}"
                           Value="{TemplateBinding Value}"
                           ViewportSize="{TemplateBinding ViewportSize}"
                           Orientation="Vertical">
                        <Track.DecreaseButton>
                            <RepeatButton Classes="sidebar-scroll-page-btn" />
                        </Track.DecreaseButton>
                        <Track.IncreaseButton>
                            <RepeatButton Classes="sidebar-scroll-page-btn" />
                        </Track.IncreaseButton>
                        <Thumb x:Name="thumb"
                               Classes="sidebar-scroll-thumb" />
                    </Track>

                    <RepeatButton x:Name="PART_LineDownButton"
                                  Grid.Row="2"
                                  Width="10"
                                  Height="10"
                                  Padding="0"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center">
                        <Path Width="6"
                              Height="4"
                              Data="M 0,0 L 3,4 L 6,0 Z"
                              Fill="{DynamicResource AccentFillColorDefaultBrush}"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </RepeatButton>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="RepeatButton.sidebar-scroll-page-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="Thumb.sidebar-scroll-thumb">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Width" Value="5" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Opacity" Value="0.88" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="999"
                        Margin="{TemplateBinding Margin}" />
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Thumb.sidebar-scroll-thumb:pointerover">
        <Setter Property="Opacity" Value="0.96" />
    </Style>

    <Style Selector="Thumb.sidebar-scroll-thumb:pressed">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ScrollBar RepeatButton /template/ TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    </Style>

    <!-- Esconde os botões de linha -->
    <Style Selector="RepeatButton.scrollbar-line-btn">
        <Setter Property="IsVisible" Value="False" />
        <Setter Property="Width" Value="0" />
        <Setter Property="Height" Value="0" />
    </Style>

    <!-- ScrollViewer mostra a scrollbar no hover -->
    <Style Selector="ScrollViewer:pointerover ScrollBar">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ScrollViewer ScrollBar:pointerover">
        <Setter Property="Opacity" Value="1" />
    </Style>

</Styles>
