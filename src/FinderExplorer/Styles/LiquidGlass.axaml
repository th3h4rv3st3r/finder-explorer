<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!--  Finder Explorer Theme — Mica Alt Dark       -->
    <!--  Inspired by Files Community app             -->
    <!-- ============================================ -->

    <!-- Global font (Files-like) -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Segoe UI Variable" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#E7EAF0" />
    </Style>

    <Styles.Resources>
        <SolidColorBrush x:Key="SidebarItemHoverBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="SidebarItemPressedBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="SidebarItemSelectedBrush" Color="#24FFFFFF" />
        <SolidColorBrush x:Key="SidebarItemSelectedBorderBrush" Color="#2FFFFFFF" />
        <SolidColorBrush x:Key="SidebarSelectionIndicatorBrush" Color="#62BEFF" />
    </Styles.Resources>

    <!-- ═══════════════ SIDEBAR ═══════════════ -->

    <!-- Section Header (Pinned, Drives, Network...) -->
    <Style Selector="ToggleButton.sidebar-section">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#A1A9BB" />
        <Setter Property="Padding" Value="8,0,8,0" />
        <Setter Property="Margin" Value="8,13,8,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.sidebar-section:pointerover">
        <Setter Property="Background" Value="#05FFFFFF" />
    </Style>

    <Style Selector="ToggleButton.sidebar-section:checked">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ToggleButton.sidebar-section:pressed">
        <Setter Property="Background" Value="#0AFFFFFF" />
    </Style>

    <Style Selector="TextBlock.section-header-label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#9CA5B7" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.section-chevron">
        <Setter Property="Text" Value="⌄" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="#8691A7" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Width" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="TextAlignment" Value="Right" />
    </Style>

    <Style Selector="ToggleButton.sidebar-section:checked TextBlock.section-chevron">
        <Setter Property="Text" Value="⌃" />
    </Style>

    <!-- Sidebar Item (button) -->
    <Style Selector="Button.sidebar-item">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#EEF2F8" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="8,0,8,0" />
        <Setter Property="Height" Value="38" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>

    <Style Selector="Button.sidebar-item:pointerover">
        <Setter Property="Background" Value="{StaticResource SidebarItemHoverBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SidebarItemHoverBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item:pressed">
        <Setter Property="Background" Value="{StaticResource SidebarItemPressedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SidebarItemPressedBrush}" />
    </Style>

    <Style Selector="Button.sidebar-item.selected">
        <Setter Property="Background" Value="{StaticResource SidebarItemSelectedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SidebarItemSelectedBorderBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item.selected:pointerover">
        <Setter Property="Background" Value="{StaticResource SidebarItemSelectedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SidebarItemSelectedBorderBrush}" />
    </Style>

    <Style Selector="Button.sidebar-item.selected:pressed">
        <Setter Property="Background" Value="{StaticResource SidebarItemSelectedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SidebarItemSelectedBorderBrush}" />
    </Style>

    <Style Selector="Button.sidebar-item:focus-visible">
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="PathIcon.sidebar-pin">
        <Setter Property="Foreground" Value="#9CA6B8" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <Style Selector="Button.sidebar-item:pointerover PathIcon.sidebar-pin">
        <Setter Property="Foreground" Value="#BEC8D8" />
    </Style>

    <Style Selector="Button.sidebar-item.selected PathIcon.sidebar-pin">
        <Setter Property="Foreground" Value="#D0D8E6" />
    </Style>

    <Style Selector="Border.sidebar-selection-indicator">
        <Setter Property="Width" Value="3" />
        <Setter Property="Height" Value="16" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Margin" Value="1,0,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource SidebarSelectionIndicatorBrush}" />
    </Style>

    <!-- ═══════════════ TOOLBAR ═══════════════ -->

    <Style Selector="Button.toolbar-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#AAFFFFFF" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="Button.toolbar-btn:pointerover">
        <Setter Property="Background" Value="#12FFFFFF" />
    </Style>

    <Style Selector="Button.toolbar-btn:pressed">
        <Setter Property="Background" Value="#18FFFFFF" />
    </Style>

    <Style Selector="Button.toolbar-btn:disabled">
        <Setter Property="Foreground" Value="#33FFFFFF" />
    </Style>

    <!-- ═══════════════ BREADCRUMB ═══════════════ -->

    <Style Selector="Button.breadcrumb-segment">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#99FFFFFF" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.breadcrumb-segment:pointerover">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Background" Value="#10FFFFFF" />
    </Style>

    <!-- ═══════════════ FILE LIST ═══════════════ -->

    <Style Selector="Border.file-item">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Margin" Value="0,1" />
    </Style>

    <Style Selector="Border.file-item:pointerover">
        <Setter Property="Background" Value="#0CFFFFFF" />
    </Style>

    <!-- ═══════════════ SCROLLBARS ═══════════════ -->

    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="True" />
    </Style>

</Styles>
