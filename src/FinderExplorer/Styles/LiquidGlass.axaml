<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!--  Finder Explorer Theme — Mica Alt Dark       -->
    <!--  Inspired by Files Community app             -->
    <!-- ============================================ -->

    <!-- Global font -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="avares://Avalonia.Fonts.Inter/Assets#Inter" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#DDFFFFFF" />
    </Style>

    <!-- ═══════════════ SIDEBAR ═══════════════ -->

    <!-- Section Header (Pinned, Drives, Network...) -->
    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#88FFFFFF" />
        <Setter Property="Padding" Value="16,18,16,6" />
    </Style>

    <!-- Sidebar Item (button) -->
    <Style Selector="Button.sidebar-item">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#BBFFFFFF" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="4,1" />
    </Style>

    <Style Selector="Button.sidebar-item:pointerover">
        <Setter Property="Background" Value="#15FFFFFF" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item:pressed">
        <Setter Property="Background" Value="#20FFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item.selected">
        <Setter Property="Background" Value="#18FFFFFF" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="Button.sidebar-item.selected:pointerover">
        <Setter Property="Background" Value="#22FFFFFF" />
    </Style>

    <!-- ═══════════════ TOOLBAR ═══════════════ -->

    <Style Selector="Button.toolbar-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#AAFFFFFF" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="Button.toolbar-btn:pointerover">
        <Setter Property="Background" Value="#12FFFFFF" />
    </Style>

    <Style Selector="Button.toolbar-btn:pressed">
        <Setter Property="Background" Value="#18FFFFFF" />
    </Style>

    <Style Selector="Button.toolbar-btn:disabled">
        <Setter Property="Foreground" Value="#33FFFFFF" />
    </Style>

    <!-- ═══════════════ BREADCRUMB ═══════════════ -->

    <Style Selector="Button.breadcrumb-segment">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#99FFFFFF" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.breadcrumb-segment:pointerover">
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Background" Value="#10FFFFFF" />
    </Style>

    <!-- ═══════════════ FILE LIST ═══════════════ -->

    <Style Selector="Border.file-item">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Margin" Value="0,1" />
    </Style>

    <Style Selector="Border.file-item:pointerover">
        <Setter Property="Background" Value="#0CFFFFFF" />
    </Style>

    <!-- ═══════════════ SCROLLBARS ═══════════════ -->

    <Style Selector="ScrollViewer">
        <Setter Property="AllowAutoHide" Value="True" />
    </Style>

</Styles>
