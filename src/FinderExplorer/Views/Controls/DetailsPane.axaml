<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FinderExplorer.ViewModels"
             xmlns:conv="using:FinderExplorer.Converters"
             xmlns:native="using:FinderExplorer.Controls"
             xmlns:vlc="using:LibVLCSharp.Avalonia"
             x:Class="FinderExplorer.Views.Controls.DetailsPane"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <conv:IconKeyConverter x:Key="IconKeyConverter" />
        <conv:UriToBitmapConverter x:Key="UriToBitmap" />
    </UserControl.Resources>

    <Border Margin="8"
            VerticalAlignment="Stretch"
            HorizontalAlignment="Stretch"
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="0">
        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0"
                    HorizontalAlignment="Center"
                    Margin="12,12,12,8"
                    Padding="2"
                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Classes="segmented-control" Classes.active="{CompiledBinding IsDetailsTabSelected}"
                            Content="Details"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Command="{CompiledBinding ShowDetailsTabCommand}" />
                    <Button Classes="segmented-control" Classes.active="{CompiledBinding IsPreviewTabSelected}"
                            Content="Preview"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Command="{CompiledBinding ShowPreviewTabCommand}" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          IsVisible="{CompiledBinding IsDetailsTabSelected}">
                <StackPanel Margin="16,4,16,16" Spacing="0">
                    <Grid Margin="0,4,0,18"
                          Height="220"
                          MaxWidth="380"
                          HorizontalAlignment="Stretch">
                        <Image Source="{CompiledBinding DetailsIconImagePath, Converter={StaticResource UriToBitmap}}"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center"
                               Stretch="Uniform"
                               RenderOptions.BitmapInterpolationMode="HighQuality"
                               IsVisible="{CompiledBinding DetailsHasImageIcon}" />
                        <PathIcon Data="{CompiledBinding DetailsIconResourceKey, Converter={StaticResource IconKeyConverter}}"
                                  Width="180"
                                  Height="180"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                  IsVisible="{CompiledBinding !DetailsHasImageIcon}" />
                    </Grid>

                    <TextBlock Text="{CompiledBinding DetailsTitleText}" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,24" />

                    <TextBlock Text="{CompiledBinding DetailsMetricLabel}" Classes="details-header" />
                    <TextBlock Text="{CompiledBinding DetailsMetricValue}" Classes="details-value" Margin="0,0,0,14" />

                    <TextBlock Text="Date Modified" Classes="details-header" />
                    <TextBlock Text="{CompiledBinding DetailsDateModifiedText}" Classes="details-value" Margin="0,0,0,14" />

                    <TextBlock Text="Date Created" Classes="details-header" />
                    <TextBlock Text="{CompiledBinding DetailsDateCreatedText}" Classes="details-value" Margin="0,0,0,14" />

                    <TextBlock Text="Item path" Classes="details-header" />
                    <TextBlock Text="{CompiledBinding DetailsPathText}"
                               Classes="details-value"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14" />

                    <Button Classes="details-props-btn"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Command="{CompiledBinding ShowPropertiesCommand}"
                            Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{DynamicResource Icon.Settings}" Width="14" Height="14"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="Properties" FontSize="13"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1"
                  IsVisible="{CompiledBinding IsPreviewTabSelected}"
                  Margin="12,6,12,12"
                  RowDefinitions="*,Auto,Auto">
                <Border Grid.Row="0"
                        Classes="preview-host-shell"
                        IsVisible="{CompiledBinding IsPreviewAvailable}">
                    <native:NativePreviewControl FilePath="{CompiledBinding PreviewFilePath}"
                                                 IsPreviewEnabled="{CompiledBinding IsNativePreviewEnabled}" />
                </Border>

                <Border Grid.Row="0"
                        Classes="preview-host-shell preview-host-image"
                        Padding="12"
                        IsVisible="{CompiledBinding IsImagePreviewAvailable}">
                    <ScrollViewer x:Name="ImagePreviewScrollViewer"
                                  Classes="preview-scroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  SizeChanged="ImagePreviewScrollViewer_OnSizeChanged"
                                  PointerWheelChanged="ImagePreviewScrollViewer_OnPointerWheelChanged">
                        <Canvas x:Name="ImagePreviewCanvas"
                                Classes="preview-canvas">
                            <Image x:Name="ImagePreviewImage"
                                   Source="{CompiledBinding ImagePreviewFilePath, Converter={StaticResource UriToBitmap}}"
                                   Stretch="Fill"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"
                                   RenderTransformOrigin="0,0" />
                        </Canvas>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="0"
                        Classes="preview-host-shell preview-host-media"
                        IsVisible="{CompiledBinding IsMediaPreviewAvailable}">
                    <vlc:VideoView x:Name="MediaPreviewVideoView"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
                </Border>

                <Border Grid.Row="0"
                        Classes="preview-host-shell"
                        Padding="16"
                        IsVisible="{CompiledBinding HasPreviewFallbackImage}">
                    <Image Source="{CompiledBinding PreviewFallbackImagePath, Converter={StaticResource UriToBitmap}}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           Stretch="Uniform"
                           StretchDirection="DownOnly"
                           RenderOptions.BitmapInterpolationMode="HighQuality" />
                </Border>

                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,8"
                        Padding="6,4"
                        Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        IsVisible="{CompiledBinding IsImagePreviewAvailable}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Classes="toolbar-btn"
                                Width="30"
                                Height="26"
                                Command="{CompiledBinding ImagePreviewZoomOutCommand}"
                                Content="-" />
                        <Button Classes="toolbar-btn"
                                MinWidth="56"
                                Height="26"
                                Command="{CompiledBinding ImagePreviewFitCommand}"
                                Content="Fit" />
                        <Button Classes="toolbar-btn"
                                MinWidth="56"
                                Height="26"
                                Command="{CompiledBinding ImagePreviewZoomResetCommand}"
                                Content="{CompiledBinding ImagePreviewZoomText}" />
                        <Button Classes="toolbar-btn"
                                Width="30"
                                Height="26"
                                Command="{CompiledBinding ImagePreviewZoomInCommand}"
                                Content="+" />
                        <Button Classes="toolbar-btn"
                                MinWidth="44"
                                Height="26"
                                Command="{CompiledBinding ImagePreviewRotateLeftCommand}"
                                Content="L" />
                        <Button Classes="toolbar-btn"
                                MinWidth="44"
                                Height="26"
                                Command="{CompiledBinding ImagePreviewRotateRightCommand}"
                                Content="R" />
                        <Button Classes="toolbar-btn"
                                Width="30"
                                Height="26"
                                Click="PanLeft_Click"
                                Content="←" />
                        <Button Classes="toolbar-btn"
                                Width="30"
                                Height="26"
                                Click="PanUp_Click"
                                Content="↑" />
                        <Button Classes="toolbar-btn"
                                Width="30"
                                Height="26"
                                Click="PanDown_Click"
                                Content="↓" />
                        <Button Classes="toolbar-btn"
                                Width="30"
                                Height="26"
                                Click="PanRight_Click"
                                Content="→" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,8"
                        Padding="6,4"
                        Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        IsVisible="{CompiledBinding IsMediaPreviewAvailable}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Classes="toolbar-btn"
                                MinWidth="56"
                                Height="26"
                                Click="MediaPlayPause_Click"
                                Content="Play/Pause" />
                        <Button Classes="toolbar-btn"
                                MinWidth="56"
                                Height="26"
                                Click="MediaStop_Click"
                                Content="Stop" />
                        <Button Classes="toolbar-btn"
                                MinWidth="56"
                                Height="26"
                                Click="MediaMute_Click"
                                Content="Mute" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2"
                           Text="{CompiledBinding PreviewStatusText}"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           IsVisible="{CompiledBinding ShowPreviewStatusText}"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </Grid>
        </Grid>
    </Border>

</UserControl>
