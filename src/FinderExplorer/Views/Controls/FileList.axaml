<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FinderExplorer.ViewModels"
             xmlns:conv="using:FinderExplorer.Converters"
             x:Class="FinderExplorer.Views.Controls.FileList"
             x:Name="FileListRoot"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <conv:IconKeyConverter x:Key="IconKeyConverter" />
        <conv:UriToBitmapConverter x:Key="UriToBitmap" />
    </UserControl.Resources>



    <Grid RowDefinitions="36,*,28"
          Margin="8,0,0,0">
        <Border Grid.Row="0"
                Classes="details-header-strip"
                Margin="0,0,12,0">
            <Grid x:Name="HeaderColumnsGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" MinWidth="48" MaxWidth="48" />
                    <ColumnDefinition Width="{CompiledBinding NameColumnWidth, Mode=TwoWay}" MinWidth="160" />
                    <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                    <ColumnDefinition Width="{CompiledBinding DateModifiedColumnWidth, Mode=TwoWay}" MinWidth="90" />
                    <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                    <ColumnDefinition Width="{CompiledBinding TypeColumnWidth, Mode=TwoWay}" MinWidth="56" />
                    <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                    <ColumnDefinition Width="{CompiledBinding SizeColumnWidth, Mode=TwoWay}" MinWidth="48" />
                    <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" />

                <Button Grid.Column="1"
                        Classes="details-header-btn"
                        Classes.active="{CompiledBinding IsSortByName}"
                        Command="{CompiledBinding SortByColumnCommand}"
                        CommandParameter="Name"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left">
                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                        <TextBlock Grid.Column="0"
                                   Text="Name"
                                   Classes="details-header-label" />
                        <PathIcon Grid.Column="1"
                                  Classes="details-header-sort"
                                  Data="{CompiledBinding SortDirectionIconKey, Converter={StaticResource IconKeyConverter}}"
                                  IsVisible="{CompiledBinding IsSortByName}" />
                    </Grid>
                </Button>

                <Button Grid.Column="3"
                        Classes="details-header-btn"
                        Classes.active="{CompiledBinding IsSortByModified}"
                        Command="{CompiledBinding SortByColumnCommand}"
                        CommandParameter="Modified"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left">
                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                        <TextBlock Grid.Column="0"
                                   Text="Date modified"
                                   Classes="details-header-label" />
                        <PathIcon Grid.Column="1"
                                  Classes="details-header-sort"
                                  Data="{CompiledBinding SortDirectionIconKey, Converter={StaticResource IconKeyConverter}}"
                                  IsVisible="{CompiledBinding IsSortByModified}" />
                    </Grid>
                </Button>

                <Button Grid.Column="5"
                        Classes="details-header-btn"
                        Classes.active="{CompiledBinding IsSortByType}"
                        Command="{CompiledBinding SortByColumnCommand}"
                        CommandParameter="Type"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left">
                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                        <TextBlock Grid.Column="0"
                                   Text="Type"
                                   Classes="details-header-label" />
                        <PathIcon Grid.Column="1"
                                  Classes="details-header-sort"
                                  Data="{CompiledBinding SortDirectionIconKey, Converter={StaticResource IconKeyConverter}}"
                                  IsVisible="{CompiledBinding IsSortByType}" />
                    </Grid>
                </Button>

                <Button Grid.Column="7"
                        Classes="details-header-btn"
                        Classes.active="{CompiledBinding IsSortBySize}"
                        Command="{CompiledBinding SortByColumnCommand}"
                        CommandParameter="Size"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left">
                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                        <TextBlock Grid.Column="0"
                                   Text="Size"
                                   Classes="details-header-label" />
                        <PathIcon Grid.Column="1"
                                  Classes="details-header-sort"
                                  Data="{CompiledBinding SortDirectionIconKey, Converter={StaticResource IconKeyConverter}}"
                                  IsVisible="{CompiledBinding IsSortBySize}" />
                    </Grid>
                </Button>

                <GridSplitter Grid.Column="2"
                              Classes="details-column-splitter"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
                <GridSplitter Grid.Column="4"
                              Classes="details-column-splitter"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
                <GridSplitter Grid.Column="6"
                              Classes="details-column-splitter"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
                <GridSplitter Grid.Column="8"
                              Classes="details-column-splitter"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ClipToBounds="True"
              HorizontalAlignment="Stretch">
            <ListBox x:Name="ItemsList"
                     Classes="file-list-listbox"
                     ItemsSource="{CompiledBinding Items}"
                     SelectedItem="{CompiledBinding SelectedItem}"
                     SelectionMode="Multiple"
                     AutoScrollToSelectedItem="False"
                     DragDrop.AllowDrop="True"
                     HorizontalAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     UseLayoutRounding="True"
                     PointerPressed="FileList_PointerPressed"
                     PointerMoved="FileList_PointerMoved"
                     PointerReleased="FileList_PointerReleased"
                     PointerCaptureLost="FileList_PointerCaptureLost">
                <ListBox.Template>
                    <ControlTemplate>
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Classes="file-scroll custom-vertical-scrollbar"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Visible"
                                      AllowAutoHide="False">
                            <ItemsPresenter x:Name="PART_ItemsPresenter"
                                            HorizontalAlignment="Stretch" />
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>

                <ListBox.ItemContainerTheme>
                    <ControlTheme TargetType="ListBoxItem" x:DataType="vm:FileItemViewModel" x:CompileBindings="False">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="{x:Null}" />
                        <Setter Property="Template">
                            <ControlTemplate>
                                <ContentPresenter Name="PART_ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch"
                                                  Padding="0" />
                            </ControlTemplate>
                        </Setter>
                    </ControlTheme>
                </ListBox.ItemContainerTheme>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:FileItemViewModel">
                        <Grid HorizontalAlignment="Stretch"
                              Width="{Binding #HeaderColumnsGrid.Bounds.Width}"
                              DoubleTapped="FileItem_DoubleTapped"
                              PointerPressed="FileItem_PointerPressed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" MinWidth="48" MaxWidth="48" />
                                <ColumnDefinition Width="{Binding #FileListRoot.DataContext.NameColumnWidth}" MinWidth="160" />
                                <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                                <ColumnDefinition Width="{Binding #FileListRoot.DataContext.DateModifiedColumnWidth}" MinWidth="90" />
                                <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                                <ColumnDefinition Width="{Binding #FileListRoot.DataContext.TypeColumnWidth}" MinWidth="56" />
                                <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                                <ColumnDefinition Width="{Binding #FileListRoot.DataContext.SizeColumnWidth}" MinWidth="48" />
                                <ColumnDefinition Width="6" MinWidth="6" MaxWidth="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Grid.ColumnSpan="8"
                                    Classes="file-row" />

                            <Border Grid.Column="0" Grid.ColumnSpan="8"
                                    Classes="file-row-pill" />

                                <Grid Grid.Column="0"
                                      Width="{Binding #FileListRoot.DataContext.FileListIconSize}"
                                      Height="{Binding #FileListRoot.DataContext.FileListIconSize}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      UseLayoutRounding="True">
                                    <Image Source="{CompiledBinding IconImagePath, Converter={StaticResource UriToBitmap}}"
                                           Width="{Binding #FileListRoot.DataContext.FileListIconSize}"
                                           Height="{Binding #FileListRoot.DataContext.FileListIconSize}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapInterpolationMode="None"
                                           IsVisible="{CompiledBinding HasImageIcon}"
                                           Classes="file-item-icon" />
                                    <PathIcon Data="{CompiledBinding IconResourceKey, Converter={StaticResource IconKeyConverter}}"
                                              Width="{Binding #FileListRoot.DataContext.FileListIconSize}"
                                              Height="{Binding #FileListRoot.DataContext.FileListIconSize}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource App.Theme.IconBaseBrush}"
                                              IsVisible="{CompiledBinding !HasImageIcon}"
                                              Classes="file-item-icon" />
                                </Grid>

                                <!-- Selection CheckBox (overlaps icon, visible on hover/selected) -->
                                <CheckBox Grid.Column="0"
                                          Classes="file-select-checkbox"
                                          IsChecked="{CompiledBinding IsSelected, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />

                                <TextBlock Grid.Column="1"
                                           Text="{CompiledBinding DisplayName}"
                                           Classes="file-cell-primary"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Margin="8,0,0,0" />
                                <TextBlock Grid.Column="3"
                                           Text="{CompiledBinding Modified, StringFormat='{}{0:dd MMMM yyyy}'}"
                                           Classes="file-cell-secondary"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Margin="8,0,0,0" />
                                <TextBlock Grid.Column="5"
                                           Text="{CompiledBinding Icon}"
                                           Classes="file-cell-secondary"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Margin="8,0,0,0" />
                                <TextBlock Grid.Column="7"
                                           Text="{CompiledBinding SizeDisplay}"
                                           Classes="file-cell-secondary"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Margin="8,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Canvas IsHitTestVisible="False">
                <Border x:Name="MarqueeSelectionBox"
                        Classes="selection-marquee"
                        IsVisible="False" />
            </Canvas>
        </Grid>

        <Border Grid.Row="2"
                Background="Transparent"
                Padding="4,0,0,0">
            <TextBlock Text="{CompiledBinding ItemCountText}"
                       FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>

</UserControl>
