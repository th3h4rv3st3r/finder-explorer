        <StreamGeometry x:Key="StatusCenterGeometry">m5,2.5c-.6,0-1,.4-1,1s.4,1,1,1,1-.4,1-1c0-.5-.5-1-1-1Zm6.5.5h-4c-.3,0-.5.2-.5.5s.2.5.5.5h4c.3,0,.5-.2.5-.5s-.2-.5-.5-.5Zm-6.5,7.5c.6,0,1-.4,1-1,0-.5-.5-1-1-1-.6,0-1,.4-1,1s.4,1,1,1Zm2.5-.5h4c.3,0,.5-.2.5-.5s-.2-.5-.5-.5h-4c-.3,0-.5.2-.5.5s.2.5.5.5Zm-2.5,3.5c.6,0,1-.4,1-1,0-.5-.5-1-1-1-.6,0-1,.4-1,1s.4,1,1,1Zm2.5-.5h4c.3,0,.5-.2.5-.5s-.2-.5-.5-.5h-4c-.3,0-.5.2-.5.5s.2.5.5.5ZM12,0H4c-1.1,0-2,1-2,2v12c0,1.1,1,2,2,2h8c1.1,0,2-1,2-2V2c0-1.1-1-2-2-2Zm1,14c0,.6-.4,1-1,1H4c-.6,0-1-.4-1-1v-7h10v7Zm0-8H3V2c0-.6.4-1,1-1h8c.5,0,1,.5,1,1v4Z</StreamGeometry>
    </UserControl.Resources>

    <Border Background="{DynamicResource App.Theme.AddressBar.BackgroundBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="4,0,4,0">
        <Grid ColumnDefinitions="Auto,*,Auto" Height="48" ColumnSpacing="4">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Classes="address-toolbar-btn" Command="{CompiledBinding NavigateBackCommand}" IsEnabled="{CompiledBinding CanNavigateBack}" ToolTip.Tip="Back (Alt+Left)">
                    <Path Data="{StaticResource NavBackGeometry}" Width="13" Height="13"
                          Stretch="Uniform"
                          Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                </Button>
                <Button Classes="address-toolbar-btn" Command="{CompiledBinding NavigateForwardCommand}" IsEnabled="{CompiledBinding CanNavigateForward}" ToolTip.Tip="Forward (Alt+Right)">
                    <Path Data="{StaticResource NavForwardGeometry}" Width="13" Height="13"
                          Stretch="Uniform"
                          Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                </Button>
                <Button Classes="address-toolbar-btn" Command="{CompiledBinding NavigateUpCommand}" IsEnabled="{CompiledBinding CanNavigateUp}" ToolTip.Tip="Up (Alt+Up)">
                    <Path Data="{StaticResource NavUpGeometry}" Width="13" Height="13"
                          Stretch="Uniform"
                          Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                </Button>
                <Button Classes="address-toolbar-btn" Command="{CompiledBinding RefreshCommand}" ToolTip.Tip="Refresh (F5)">
                    <Path Data="{StaticResource RefreshGeometry}" Width="13" Height="13"
                          Stretch="Uniform"
                          Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                </Button>
            </StackPanel>

            <Border Grid.Column="1" Classes="omnibar-shell">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                    <!-- Path mode -->
                    <Grid x:Name="PathModeHost" Grid.Column="0" VerticalAlignment="Center">
                        <Grid ColumnDefinitions="Auto,*">
                            <Button Grid.Column="0"
                                    Classes="omnibar-home-btn"
                                    Command="{CompiledBinding SidebarNavigateCommand}"
                                    CommandParameter="{CompiledBinding SidebarHome}"
                                    ToolTip.Tip="Home">
                                <Image Source="avares://FinderExplorer/Assets/Icons/WinUI/Home.png"
                                       Width="16"
                                       Height="16"
                                       RenderOptions.BitmapInterpolationMode="HighQuality" />
                            </Button>

                            <ScrollViewer Grid.Column="1"
                                          Margin="0,0,6,0"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Center">
                                <ItemsControl ItemsSource="{CompiledBinding BreadcrumbSegments}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BreadcrumbSegmentViewModel">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource ChevronRightGeometry}"
                                                      Width="10"
                                                      Height="10"
                                                      IsVisible="{CompiledBinding ShowSeparator}"
                                                      Margin="2,0,2,0"
                                                      Stretch="Uniform"
                                                      Fill="{DynamicResource TextFillColorTertiaryBrush}" />
                                                <Button Classes="omnibar-crumb-btn"
                                                        ToolTip.Tip="{CompiledBinding FullPath}"
                                                        Command="{CompiledBinding $parent[UserControl].((vm:MainWindowViewModel)DataContext).BreadcrumbNavigateCommand}"
                                                        CommandParameter="{CompiledBinding}">
                                                    <TextBlock Text="{CompiledBinding Label}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- Command palette mode -->
                    <Grid x:Name="CommandPaletteModeHost"
                          Grid.Column="0"
                          IsVisible="False"
                          ColumnDefinitions="Auto,*"
                          VerticalAlignment="Center">
                        <Path Grid.Column="0"
                              x:Name="CommandPaletteModeGlyph"
                              Data="{StaticResource CommandPaletteGeometry}"
                              Width="15"
                              Height="15"
                              Margin="12,0,8,0"
                              Stretch="Uniform"
                              Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="CommandPaletteBox"
                                 Grid.Column="1"
                                 Classes="omnibar-input"
                                 Watermark="Run a command"
                                 KeyDown="CommandPaletteBox_KeyDown" />
                    </Grid>

                    <!-- Search mode -->
                    <Grid x:Name="SearchModeHost"
                          Grid.Column="0"
                          IsVisible="False"
                          ColumnDefinitions="Auto,*"
                          VerticalAlignment="Center">
                        <Path Grid.Column="0"
                              x:Name="SearchModeGlyph"
                              Data="{StaticResource SearchGeometry}"
                              Width="14"
                              Height="14"
                              Margin="12,0,8,0"
                              Stretch="Uniform"
                              Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Classes="omnibar-input"
                                 Text="{CompiledBinding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="Search in this folder"
                                 KeyDown="SearchBox_KeyDown" />
                    </Grid>

                    <Border Grid.Column="1" Classes="omnibar-separator" />
                    <Button x:Name="CommandPaletteModeButton"
                            Grid.Column="2"
                            Classes="omnibar-mode-btn"
                            ToolTip.Tip="Command palette (Ctrl+Shift+P)"
                            Click="CommandPaletteModeButton_Click">
                        <Path x:Name="CommandPaletteToggleIcon"
                              Data="{StaticResource CommandPaletteGeometry}"
                              Width="15"
                              Height="15"
                              Stretch="Uniform"
                              Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Button>

                    <Border Grid.Column="3" Classes="omnibar-separator" />
                    <Button x:Name="SearchModeButton"
                            Grid.Column="4"
                            Classes="omnibar-mode-btn"
                            ToolTip.Tip="Search mode (Ctrl+F)"
                            Click="SearchModeButton_Click">
                        <Path x:Name="SearchToggleIcon"
                              Data="{StaticResource SearchGeometry}"
                              Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Button>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button x:Name="ShowStatusCenterButton"
                        Classes="address-toolbar-btn"
                        ToolTip.Tip="Status center">
                    <Path Data="{StaticResource StatusCenterGeometry}"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Fill="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <controls:StatusCenterFlyout DataContext="{Binding}" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
