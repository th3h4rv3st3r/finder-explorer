<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FinderExplorer.ViewModels"
             x:Class="FinderExplorer.Views.Controls.NavigationBar"
             x:DataType="vm:MainWindowViewModel">

    <Border Background="{DynamicResource App.Theme.AddressBar.BackgroundBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="4,0,4,0">
        <Grid ColumnDefinitions="Auto,*,Auto" Height="48" ColumnSpacing="4">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Classes="nav-btn" Command="{CompiledBinding NavigateBackCommand}" IsEnabled="{CompiledBinding CanNavigateBack}" ToolTip.Tip="Back (Alt+Left)">
                    <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.NavBack}" Width="14" Height="14" />
                </Button>
                <Button Classes="nav-btn" Command="{CompiledBinding NavigateForwardCommand}" IsEnabled="{CompiledBinding CanNavigateForward}" ToolTip.Tip="Forward (Alt+Right)">
                    <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.NavForward}" Width="14" Height="14" />
                </Button>
                <Button Classes="nav-btn" Command="{CompiledBinding NavigateUpCommand}" IsEnabled="{CompiledBinding CanNavigateUp}" ToolTip.Tip="Up (Alt+Up)">
                    <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.NavUp}" Width="14" Height="14" />
                </Button>
                <Button Classes="nav-btn" Command="{CompiledBinding RefreshCommand}" ToolTip.Tip="Refresh (F5)">
                    <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.Refresh}" Width="14" Height="14" />
                </Button>
            </StackPanel>

            <Border Grid.Column="1" Margin="0"
                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="6"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0" Classes="nav-btn" Width="36" Height="32"
                            Command="{CompiledBinding SidebarNavigateCommand}" CommandParameter="{CompiledBinding SidebarHome}"
                            ToolTip.Tip="Home">
                        <PathIcon Data="{DynamicResource Icon.Home}" Width="14" Height="14"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Button>

                    <ScrollViewer Grid.Column="1"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  VerticalAlignment="Center">
                        <ItemsControl ItemsSource="{CompiledBinding BreadcrumbSegments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:BreadcrumbSegmentViewModel">
                                    <StackPanel Orientation="Horizontal">
                                        <PathIcon Data="{DynamicResource Icon.ChevronRight}" Width="10" Height="10"
                                                  IsVisible="{CompiledBinding ShowSeparator}"
                                                  Margin="2,0,2,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <Button Classes="breadcrumb-btn" Content="{CompiledBinding Label}" ToolTip.Tip="{CompiledBinding FullPath}"
                                                Command="{CompiledBinding $parent[UserControl].((vm:MainWindowViewModel)DataContext).BreadcrumbNavigateCommand}"
                                                CommandParameter="{CompiledBinding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="2" ColumnDefinitions="Auto,Auto" VerticalAlignment="Center">
                <Border Grid.Column="0"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Width="286"
                        Height="32"
                        Margin="0,0,4,0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <PathIcon Grid.Column="0" Data="{DynamicResource Icon.Search}" Width="14" Height="14"
                                  Margin="8,0,6,0" VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="SearchBox" Grid.Column="1"
                                 Classes="search-box"
                                 Text="{CompiledBinding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 Watermark="Search in this folder"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 VerticalContentAlignment="Center">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                            </TextBox.KeyBindings>
                        </TextBox>
                        <Button Grid.Column="2" Classes="toolbar-btn" Width="28" Height="28" Margin="0,0,2,0"
                                Command="{CompiledBinding SearchCommand}"
                                ToolTip.Tip="Search (Enter)">
                            <PathIcon Data="{DynamicResource Icon.Search}" Width="13" Height="13"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Button>
                    </Grid>
                </Border>

                <Button Grid.Column="1" Classes="toolbar-btn" Width="36" Height="32"
                        ToolTip.Tip="Details pane"
                        Command="{CompiledBinding ToggleDetailsPaneCommand}">
                    <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.Panes.Right}" Width="15" Height="15" />
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
