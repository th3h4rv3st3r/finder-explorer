<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FinderExplorer.ViewModels"
        xmlns:conv="using:FinderExplorer.Converters"
        x:Class="FinderExplorer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{CompiledBinding WindowTitle}"
        Width="1100" Height="700"
        MinWidth="700" MinHeight="450"
        Icon="avares://FinderExplorer/Assets/app-icon.ico"
        Background="Transparent"
        TransparencyLevelHint="Mica"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40">

    <Window.Resources>
        <conv:UriToBitmapConverter x:Key="UriToBitmap" />
        <conv:IconKeyConverter x:Key="IconKeyConverter" />
        <conv:FolderOrFileIconConverter x:Key="FolderOrFileIconConverter" />
    </Window.Resources>

    <Grid ColumnDefinitions="220,*">

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0"
                Background="#E8202020"
                BorderBrush="#18FFFFFF"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="40,*,Auto">

                <!-- Title bar drag region -->
                <Border Grid.Row="0" IsHitTestVisible="False" />

                <ScrollViewer Grid.Row="1" Padding="4,0"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="0" Margin="0,4,0,8">

                        <!-- ── HOME ── -->
                        <Button Classes="sidebar-item"
                                Command="{CompiledBinding SidebarNavigateCommand}"
                                CommandParameter="{CompiledBinding SidebarHome}"
                                Classes.selected="{CompiledBinding SidebarHome.IsSelected}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Image Source="avares://FinderExplorer/Assets/Icons/Home.png"
                                       Width="16" Height="16" />
                                <TextBlock Text="Home" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- ── PINNED ── -->
                        <TextBlock Classes="section-header" Text="PINNED" />

                        <ItemsControl ItemsSource="{CompiledBinding SidebarFavorites}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SidebarItemViewModel">
                                    <Button Classes="sidebar-item"
                                            Classes.selected="{CompiledBinding IsSelected}"
                                            Command="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).SidebarNavigateCommand}"
                                            CommandParameter="{CompiledBinding}">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <PathIcon Data="{Binding IconKey, Converter={StaticResource IconKeyConverter}}"
                                                      Width="16" Height="16"
                                                      Foreground="#CCFFFFFF" />
                                            <TextBlock Text="{CompiledBinding Label}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ── DRIVES ── -->
                        <TextBlock Classes="section-header" Text="DRIVES" />

                        <ItemsControl ItemsSource="{CompiledBinding SidebarVolumes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SidebarItemViewModel">
                                    <Button Classes="sidebar-item"
                                            Classes.selected="{CompiledBinding IsSelected}"
                                            Command="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).SidebarNavigateCommand}"
                                            CommandParameter="{CompiledBinding}">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <PathIcon Data="{Binding IconKey, Converter={StaticResource IconKeyConverter}}"
                                                      Width="16" Height="16"
                                                      Foreground="#CCFFFFFF" />
                                            <TextBlock Text="{CompiledBinding Label}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ── NETWORK ── -->
                        <TextBlock Classes="section-header" Text="NETWORK" />

                        <Button Classes="sidebar-item" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.Settings.General.Connections}"
                                          Width="16" Height="16"
                                          Foreground="#66FFFFFF" />
                                <TextBlock Text="Network" Foreground="#66FFFFFF"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- ── NEXTCLOUD ── -->
                        <TextBlock Classes="section-header" Text="NEXTCLOUD" />

                        <Button Classes="sidebar-item" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.Status.Cloud}"
                                          Width="16" Height="16"
                                          Foreground="#66FFFFFF" />
                                <TextBlock Text="Nextcloud" Foreground="#66FFFFFF"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: Settings -->
                <Border Grid.Row="2"
                        BorderBrush="#18FFFFFF"
                        BorderThickness="0,1,0,0"
                        Padding="4,4">
                    <Button Classes="sidebar-item">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.Settings}"
                                      Width="16" Height="16"
                                      Foreground="#AAFFFFFF" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Column="1" RowDefinitions="40,36,*,24">

            <!-- Toolbar -->
            <Border Grid.Row="0"
                    Background="#08FFFFFF"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto,Auto,*" Margin="4,0">
                    <!-- Navigation buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                Spacing="2" VerticalAlignment="Center">
                        <Button Classes="toolbar-btn"
                                Command="{CompiledBinding NavigateUpCommand}"
                                ToolTip.Tip="Back">
                            <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.NavBack}"
                                      Width="14" Height="14" />
                        </Button>
                        <Button Classes="toolbar-btn" IsEnabled="False"
                                ToolTip.Tip="Forward">
                            <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.NavForward}"
                                      Width="14" Height="14" />
                        </Button>
                        <Button Classes="toolbar-btn"
                                Command="{CompiledBinding NavigateUpCommand}"
                                ToolTip.Tip="Parent folder">
                            <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.NavUp}"
                                      Width="14" Height="14" />
                        </Button>
                    </StackPanel>
                    <!-- Refresh -->
                    <Button Grid.Column="1" Classes="toolbar-btn" Margin="4,0,0,0"
                            Command="{CompiledBinding RefreshCommand}"
                            ToolTip.Tip="Refresh">
                        <PathIcon Data="{DynamicResource Icon.Files.App.ThemedIcons.Refresh}"
                                  Width="14" Height="14" />
                    </Button>
                    <!-- Drag area -->
                    <Border Grid.Column="2" IsHitTestVisible="False" />
                </Grid>
            </Border>

            <!-- Breadcrumb / Address Bar -->
            <Border Grid.Row="1"
                    Background="#0AFFFFFF"
                    Margin="8,4,8,0"
                    CornerRadius="6"
                    Padding="4,0"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="1">
                <ItemsControl ItemsSource="{CompiledBinding BreadcrumbSegments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="0"
                                        VerticalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:BreadcrumbSegmentViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="0">
                                <TextBlock Text="›" Foreground="#44FFFFFF"
                                           VerticalAlignment="Center"
                                           FontSize="16" Margin="2,0" />
                                <Button Classes="breadcrumb-segment"
                                        Content="{CompiledBinding Label}"
                                        Command="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).BreadcrumbNavigateCommand}"
                                        CommandParameter="{CompiledBinding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- File List -->
            <Border Grid.Row="2" Margin="8,4,8,0">
                <Grid RowDefinitions="28,*">
                    <!-- Column Headers -->
                    <Border Grid.Row="0"
                            BorderBrush="#10FFFFFF"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="36,*,90,150" Margin="8,0">
                            <TextBlock Grid.Column="1" Text="Name"
                                       Classes="col-header" />
                            <TextBlock Grid.Column="2" Text="Size"
                                       Classes="col-header"
                                       HorizontalAlignment="Right" />
                            <TextBlock Grid.Column="3" Text="Modified"
                                       Classes="col-header"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </Border>

                    <!-- Items -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{CompiledBinding Items}"
                             SelectedItem="{CompiledBinding SelectedItem}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileItemViewModel">
                                <Border Classes="file-item"
                                        DoubleTapped="FileItem_DoubleTapped">
                                    <Grid ColumnDefinitions="36,*,90,150">
                                        <!-- File icon: folder or file -->
                                        <PathIcon Grid.Column="0"
                                                  Data="{CompiledBinding IsDirectory, Converter={StaticResource FolderOrFileIconConverter}}"
                                                  Width="18" Height="18"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="#AAFFFFFF" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{CompiledBinding Name}"
                                                   FontSize="13"
                                                   Foreground="#DDFFFFFF"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{CompiledBinding SizeDisplay}"
                                                   FontSize="12"
                                                   Foreground="#77FFFFFF"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{CompiledBinding Modified, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                   FontSize="12"
                                                   Foreground="#77FFFFFF"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="3"
                    Background="#08FFFFFF"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,1,0,0"
                    Padding="12,0">
                <TextBlock Text="{CompiledBinding ItemCountText}"
                           FontSize="11"
                           Foreground="#66FFFFFF"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</Window>
