<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FinderExplorer.ViewModels"
        x:Class="FinderExplorer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{CompiledBinding WindowTitle}"
        Width="1100" Height="700"
        MinWidth="700" MinHeight="450"
        Background="#E6181818"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40">

    <Grid ColumnDefinitions="220,*">

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0"
                Classes="glass-panel"
                Margin="8,8,0,8">
            <Grid RowDefinitions="40,*">
                <!-- Drag region / Title -->
                <TextBlock Grid.Row="0"
                           Text="Finder Explorer"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#99FFFFFF"
                           VerticalAlignment="Center"
                           Margin="56,0,0,0"
                           IsHitTestVisible="False" />

                <ScrollViewer Grid.Row="1" Padding="6,0">
                    <StackPanel Spacing="0">
                        <!-- Favorites -->
                        <TextBlock Classes="section-label" Text="FAVORITOS" />
                        <ItemsControl ItemsSource="{CompiledBinding SidebarFavorites}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SidebarItemViewModel">
                                    <Button Classes="sidebar-item"
                                            Command="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).SidebarNavigateCommand}"
                                            CommandParameter="{CompiledBinding}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{CompiledBinding Icon}" FontSize="15" VerticalAlignment="Center" />
                                            <TextBlock Text="{CompiledBinding Label}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Volumes -->
                        <TextBlock Classes="section-label" Text="VOLUMES" Margin="12,20,12,4" />
                        <ItemsControl ItemsSource="{CompiledBinding SidebarVolumes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SidebarItemViewModel">
                                    <Button Classes="sidebar-item"
                                            Command="{CompiledBinding $parent[Window].((vm:MainWindowViewModel)DataContext).SidebarNavigateCommand}"
                                            CommandParameter="{CompiledBinding}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{CompiledBinding Icon}" FontSize="15" VerticalAlignment="Center" />
                                            <TextBlock Text="{CompiledBinding Label}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Column="1" RowDefinitions="40,36,*" Margin="8">

            <!-- Toolbar -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto">
                <!-- Back / Forward / Up -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Classes="toolbar-btn" Content="◀" Command="{CompiledBinding NavigateUpCommand}" ToolTip.Tip="Voltar" />
                    <Button Classes="toolbar-btn" Content="▲" Command="{CompiledBinding NavigateUpCommand}" ToolTip.Tip="Pasta pai" />
                </StackPanel>

                <!-- Window Title (for drag area) -->
                <TextBlock Grid.Column="2"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#66FFFFFF"
                           IsHitTestVisible="False" />
            </Grid>

            <!-- Breadcrumb -->
            <Border Grid.Row="1" Classes="glass-panel" Padding="4,0" Margin="0,0,0,4">
                <ItemsControl ItemsSource="{CompiledBinding BreadcrumbSegments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <TextBlock Text="›" Foreground="#44FFFFFF" VerticalAlignment="Center" FontSize="16" />
                                <Button Classes="breadcrumb-segment" Content="{CompiledBinding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- File List -->
            <Border Grid.Row="2" Classes="glass-panel" Padding="4">
                <Grid RowDefinitions="28,*">
                    <!-- Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="40,*,90,150" Margin="8,0">
                        <TextBlock Grid.Column="0" Text="" FontSize="11" Foreground="#55FFFFFF" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Nome" FontSize="11" Foreground="#55FFFFFF" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Tamanho" FontSize="11" Foreground="#55FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="Modificado" FontSize="11" Foreground="#55FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>

                    <!-- Items -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{CompiledBinding Items}"
                             SelectedItem="{CompiledBinding SelectedItem}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileItemViewModel">
                                <Border Classes="file-item" DoubleTapped="FileItem_DoubleTapped">
                                    <Grid ColumnDefinitions="40,*,90,150">
                                        <TextBlock Grid.Column="0" Text="{CompiledBinding Icon}" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{CompiledBinding Name}" FontSize="13" Foreground="#DDFFFFFF" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{CompiledBinding SizeDisplay}" FontSize="12" Foreground="#77FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="3" Text="{CompiledBinding Modified, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" FontSize="12" Foreground="#77FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
