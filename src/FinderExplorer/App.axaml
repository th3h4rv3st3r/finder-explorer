<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FinderExplorer.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <!--
            Usando SimpleTheme em vez de FluentTheme.
            O FluentTheme injeta MinHeight, Padding e ControlThemes em Button/ToggleButton
            que interferem com nossos tamanhos fixos — especialmente em fullscreen onde
            o Avalonia recomputa a caption area e força re-layout dos controles.
            O SimpleTheme fornece apenas o mínimo necessário (ScrollViewer, TextBlock, etc.)
            sem sobrescrever Button/ToggleButton, que definimos inteiramente nos nossos estilos.
        -->
        <SimpleTheme />
        <StyleInclude Source="avares://FinderExplorer/Styles/LiquidGlass.axaml" />
        <StyleInclude Source="avares://FinderExplorer/Styles/NavigationToolbar.axaml" />
        <StyleInclude Source="avares://FinderExplorer/Styles/ContentArea.axaml" />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://FinderExplorer/Styles/WinUIColors.axaml" />
                <ResourceInclude Source="avares://FinderExplorer/Styles/FilesThemedIcons.axaml" />
                <ResourceInclude Source="avares://FinderExplorer/Styles/AppIcons.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
